#!name=应用安装
#!category=应用
#!desc=App Store 低版本应用安装、已购下架应用安装

[Script]
应用接口 = type=http-request,pattern=https://apple-api.com,requires-body=1,max-size=-1,binary-body-mode=0,timeout=30,debug=1,script-path=Scripts/AppStoreIPA/AppleStoreAPI.js

应用安装 = type=http-request,pattern=https:\/\/xiaobai\.app,requires-body=0,script-path=Scripts/AppStoreIPA/installapp.js

[MITM]
hostname = %APPEND%  apple-api.com, xiaobai.app